{
  "version": 4,
  "terraform_version": "1.5.0",
  "serial": 10,
  "lineage": "security-audit-test",
  "resources": [
    {
      "mode": "managed",
      "type": "aws_db_instance",
      "name": "public_db",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "public-db-instance",
            "arn": "arn:aws:rds:us-east-1:123456789012:db:public-db",
            "identifier": "public-db",
            "engine": "mysql",
            "engine_version": "8.0",
            "instance_class": "db.t3.micro",
            "publicly_accessible": true,
            "storage_encrypted": false,
            "deletion_protection": false,
            "multi_az": false,
            "region": "us-east-1",
            "tags": {
              "env": "production"
            }
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_db_instance",
      "name": "secure_db",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "secure-db-instance",
            "arn": "arn:aws:rds:us-east-1:123456789012:db:secure-db",
            "identifier": "secure-db",
            "engine": "postgres",
            "engine_version": "15.3",
            "instance_class": "db.r5.large",
            "publicly_accessible": false,
            "storage_encrypted": true,
            "deletion_protection": true,
            "multi_az": true,
            "region": "us-east-1",
            "tags": {
              "env": "production"
            }
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_security_group",
      "name": "wide_open",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "sg-wide-open",
            "name": "wide-open-sg",
            "vpc_id": "vpc-123",
            "ingress": [
              {
                "from_port": 0,
                "to_port": 65535,
                "protocol": "tcp",
                "cidr_blocks": ["0.0.0.0/0"],
                "ipv6_cidr_blocks": ["::/0"]
              }
            ],
            "egress": [
              {
                "from_port": 0,
                "to_port": 0,
                "protocol": "-1",
                "cidr_blocks": ["0.0.0.0/0"]
              }
            ],
            "tags": {}
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_security_group",
      "name": "restricted",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "sg-restricted",
            "name": "restricted-sg",
            "vpc_id": "vpc-123",
            "ingress": [
              {
                "from_port": 443,
                "to_port": 443,
                "protocol": "tcp",
                "cidr_blocks": ["10.0.0.0/8"]
              }
            ],
            "tags": {}
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_s3_bucket",
      "name": "public_bucket",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "my-public-bucket",
            "bucket": "my-public-bucket",
            "arn": "arn:aws:s3:::my-public-bucket",
            "acl": "public-read",
            "region": "us-east-1",
            "versioning": [
              {
                "enabled": false
              }
            ],
            "tags": {}
          }
        }
      ]
    },
    {
      "mode": "managed",
      "type": "aws_instance",
      "name": "public_vm",
      "provider": "provider[\"registry.terraform.io/hashicorp/aws\"]",
      "instances": [
        {
          "attributes": {
            "id": "i-public-vm",
            "instance_type": "t3.micro",
            "ami": "ami-12345678",
            "public_ip": "54.100.200.1",
            "associate_public_ip_address": true,
            "region": "us-east-1",
            "tags": {
              "Name": "public-vm"
            }
          }
        }
      ]
    }
  ]
}
